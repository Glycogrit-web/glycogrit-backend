{
  "enabled": true,
  "auto_detect": true,
  "require_approval": true,
  "watch_patterns": [
    "app/**/*.py",
    "app/api/**/*.py",
    "app/models/**/*.py",
    "app/schemas/**/*.py",
    "app/core/*.py",
    "app/middleware/**/*.py",
    "alembic/versions/*.py",
    "requirements.txt",
    "docker-compose.yml",
    "Dockerfile"
  ],
  "wiki_pages": {
    "design_patterns": {
      "file": "Design-Patterns.md",
      "triggers": [
        "new_service_class",
        "new_repository_pattern",
        "dependency_injection",
        "middleware_pattern"
      ]
    },
    "api_documentation": {
      "file": "API-Documentation.md",
      "triggers": [
        "new_endpoint",
        "endpoint_modified",
        "new_router",
        "authentication_change"
      ]
    },
    "database_schema": {
      "file": "Database-Schema.md",
      "triggers": [
        "new_model",
        "model_modified",
        "new_relationship",
        "migration_created"
      ]
    },
    "security_practices": {
      "file": "Security-Best-Practices.md",
      "triggers": [
        "auth_change",
        "new_middleware",
        "validation_pattern",
        "security_header"
      ]
    },
    "configuration": {
      "file": "Configuration-Guide.md",
      "triggers": [
        "new_env_variable",
        "settings_modified",
        "docker_config_change"
      ]
    }
  },
  "detection_rules": {
    "new_endpoint": {
      "pattern": "@router\\.(get|post|put|delete|patch)",
      "files": ["app/api/**/*.py"]
    },
    "new_model": {
      "pattern": "class \\w+\\(Base\\):",
      "files": ["app/models/**/*.py"]
    },
    "new_schema": {
      "pattern": "class \\w+\\(BaseModel\\):",
      "files": ["app/schemas/**/*.py"]
    },
    "auth_change": {
      "pattern": "(auth|firebase|token|jwt|authenticate)",
      "files": ["app/middleware/**/*.py", "app/core/firebase.py"]
    },
    "settings_change": {
      "pattern": "class Settings\\(BaseSettings\\):",
      "files": ["app/core/config.py"]
    },
    "migration": {
      "pattern": "def upgrade\\(\\)|def downgrade\\(\\)",
      "files": ["alembic/versions/*.py"]
    }
  },
  "logging": {
    "enabled": true,
    "directory": ".claude/wiki-updates",
    "files": {
      "history": "history.json",
      "pending": "pending.json",
      "applied": "applied.json"
    }
  },
  "safety": {
    "dry_run": false,
    "show_diff": true,
    "conflict_detection": true,
    "rollback_support": true,
    "max_rollback_count": 10
  }
}
