{
  "enabled": true,
  "auto_review": true,
  "rules": {
    "type_hints": {
      "level": "error",
      "description": "All functions must have type hints for parameters and return values"
    },
    "response_models": {
      "level": "error",
      "description": "All API endpoints must define response_model"
    },
    "security": {
      "level": "error",
      "description": "No hardcoded secrets, proper input validation, SQL injection prevention"
    },
    "performance": {
      "level": "warning",
      "description": "Avoid N+1 queries, use eager loading, implement pagination"
    },
    "documentation": {
      "level": "warning",
      "description": "Docstrings on public functions, API endpoint descriptions"
    },
    "code_organization": {
      "level": "warning",
      "description": "Functions under 50 lines, single responsibility, no duplication"
    },
    "async_patterns": {
      "level": "error",
      "description": "Use async/await correctly, async database sessions"
    },
    "error_handling": {
      "level": "error",
      "description": "Proper HTTPException usage, meaningful error messages"
    }
  },
  "ignore_patterns": [
    "tests/**",
    "alembic/versions/**",
    "**/__pycache__/**",
    "**/.*"
  ],
  "file_patterns": [
    "app/**/*.py"
  ],
  "thresholds": {
    "max_function_length": 50,
    "max_file_length": 500,
    "max_complexity": 10,
    "min_test_coverage": 70
  },
  "checks": {
    "file_organization": true,
    "fastapi_best_practices": true,
    "type_hints": true,
    "sqlalchemy_patterns": true,
    "pydantic_schemas": true,
    "authentication": true,
    "error_handling": true,
    "security": true,
    "code_organization": true,
    "testing": true,
    "documentation": true,
    "performance": true
  },
  "security_checks": {
    "hardcoded_secrets": true,
    "sql_injection": true,
    "xss_prevention": true,
    "input_validation": true,
    "authentication": true,
    "authorization": true,
    "sensitive_data_logging": true
  },
  "reporting": {
    "format": "markdown",
    "show_passed": true,
    "show_warnings": true,
    "show_errors": true,
    "show_recommendations": true,
    "group_by": "category"
  },
  "integration": {
    "git_pre_commit": false,
    "git_pre_push": false,
    "on_file_save": true,
    "manual_trigger": true
  },
  "logging": {
    "enabled": true,
    "directory": ".claude/code-review",
    "files": {
      "history": "history.json",
      "reports": "reports/"
    }
  }
}
