{
  "enabled": true,
  "auto_load": true,
  "default_mode": "full",
  "cache": {
    "enabled": true,
    "duration": 3600,
    "max_size_mb": 10,
    "directory": ".claude/cache"
  },
  "modes": {
    "full": {
      "description": "Complete project context for comprehensive understanding",
      "files": [
        "README.md",
        "RAILWAY_DEPLOYMENT.md",
        "QUICK_START.md"
      ]
    },
    "api": {
      "description": "Context for API development",
      "files": [
        "README.md",
        "RAILWAY_DEPLOYMENT.md"
      ]
    },
    "deployment": {
      "description": "Context for deployment and DevOps tasks",
      "files": [
        "RAILWAY_DEPLOYMENT.md",
        "QUICK_START.md",
        "DOPPLER_QUICKSTART.md"
      ]
    },
    "minimal": {
      "description": "Minimal context for quick tasks",
      "files": [
        "README.md"
      ]
    }
  },
  "auto_detect": {
    "enabled": true,
    "patterns": {
      "app/main.py": "api",
      "app/core/config.py": "deployment",
      "nixpacks.toml": "deployment",
      "railway.json": "deployment",
      "requirements.txt": "deployment"
    }
  },
  "refresh_triggers": {
    "wiki_file_modified": true,
    "adr_created": true,
    "manual_refresh": true
  },
  "loading": {
    "progressive": true,
    "lazy_load_adrs": false,
    "max_file_size_kb": 500
  },
  "output": {
    "format": "markdown",
    "include_metadata": true,
    "show_last_updated": true,
    "show_related_adrs": true
  }
}
