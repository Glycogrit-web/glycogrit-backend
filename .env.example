# =============================================================================
# DEPLOYMENT PLATFORM
# =============================================================================
# Options: local, railway
DEPLOYMENT_PLATFORM=local

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For local development
POSTGRES_USER=glycogrit
POSTGRES_PASSWORD=glycogrit123
POSTGRES_DB=glycogrit
POSTGRES_PORT=5432

# Database URL
# - Local: postgresql://glycogrit:glycogrit123@localhost:5432/glycogrit
# - Railway: Automatically provided as DATABASE_URL (don't set manually)
DATABASE_URL=postgresql://glycogrit:glycogrit123@localhost:5432/glycogrit

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server port (Railway sets this automatically via $PORT)
PORT=8000
HOST=0.0.0.0

# Backend port (for local dev)
BACKEND_PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development

# =============================================================================
# RAILWAY-SPECIFIC (Auto-set by Railway)
# =============================================================================
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_ID=your-project-id
# RAILWAY_SERVICE_ID=your-service-id

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Option 1: File path (for local development)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Option 2: JSON string (for Railway - recommended)
# Paste entire JSON content from firebase-credentials.json as a single line
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
# Local: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# SECURITY NOTES
# =============================================================================
# ⚠️  NEVER commit actual secrets to git!
# ⚠️  Use Doppler or Railway secrets for production
# ⚠️  Rotate JWT_SECRET_KEY regularly
# ⚠️  Use strong POSTGRES_PASSWORD in production
