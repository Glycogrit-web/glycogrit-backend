# ⚠️ DO NOT PUT SECRETS IN THIS FILE ⚠️
# All secrets are managed in unified Doppler project: glycogrit

# This is just an example file showing what variables exist
# The actual values are stored in Doppler

# To run the application:
# ./start.sh development   # Local development
# ./start.sh staging       # Test with staging config
# ./start.sh production    # Test with production config

# Backend Variables managed in Doppler:
# ENVIRONMENT=development|staging|production
# PORT=8000
# HOST=0.0.0.0
# DATABASE_URL=postgresql://...
# ALLOWED_ORIGINS=comma,separated,urls
# SECRET_KEY=unique-per-environment
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60  # Default: 60 minutes (1 hour). Override only if needed.
# DEBUG=True|False
# RAILWAY_PUBLIC_URL=https://web-production-188d1.up.railway.app
# RAILWAY_PRIVATE_URL=web.railway.internal
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:5173
# STRAVA_CLIENT_ID=your-strava-client-id
# STRAVA_CLIENT_SECRET=your-strava-client-secret
# STRAVA_REDIRECT_URI=http://localhost:5173/auth/strava/callback
#
# Fitbit API Configuration
# FITBIT_CLIENT_ID=your-fitbit-client-id
# FITBIT_CLIENT_SECRET=your-fitbit-client-secret
# FITBIT_REDIRECT_URI=http://localhost:5173/auth/fitbit/callback
#
# Google Fit API Configuration
# GOOGLE_FIT_CLIENT_ID=your-google-fit-client-id
# GOOGLE_FIT_CLIENT_SECRET=your-google-fit-client-secret
# GOOGLE_FIT_REDIRECT_URI=http://localhost:5173/auth/google-fit/callback
#
# Payment Gateway Configuration
# DEFAULT_PAYMENT_GATEWAY=razorpay  # Options: razorpay, stripe, paypal (add more as implemented)
#
# Razorpay (Primary Payment Gateway)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
#
# Stripe (Future - not yet implemented)
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
#
# Cloudflare R2 Storage Configuration
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=glycogrit-events
# R2_PUBLIC_URL=https://your-custom-domain.com  # Optional: Custom domain for R2 bucket
#
# Shiprocket Configuration (Medal/Certificate Shipping)
# SHIPROCKET_EMAIL=your-shiprocket-email@example.com
# SHIPROCKET_PASSWORD=your-shiprocket-password
# SHIPROCKET_WEBHOOK_SECRET=webhook-secret-from-shiprocket-dashboard
# # Default Package Settings (medals + certificates)
# SHIPROCKET_DEFAULT_LENGTH=15  # cm
# SHIPROCKET_DEFAULT_BREADTH=10  # cm
# SHIPROCKET_DEFAULT_HEIGHT=5  # cm
# SHIPROCKET_DEFAULT_WEIGHT=0.5  # kg
# SHIPROCKET_PICKUP_LOCATION_NAME=GlycoGrit Warehouse
#
# Instagram API Configuration (for Gallery Submissions)
# INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
# INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# Frontend Variables (also in same Doppler project):
# VITE_APP_NAME=GlycoGrit (Dev)|GlycoGrit (Staging)|GlycoGrit
# VITE_ENABLE_ANALYTICS=true|false
# VITE_ENABLE_DEBUG_MODE=true|false
# VITE_ENVIRONMENT=development|staging|production
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
# VITE_INSTAGRAM_ACCESS_TOKEN=...
